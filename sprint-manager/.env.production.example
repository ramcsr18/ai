PORT=4000

REACT_APP_API_BASE_URL=
REACT_APP_ORACLE_DOMAIN_URL=https://your-oracle-domain.identity.oraclecloud.com
REACT_APP_ORACLE_CLIENT_ID=your-public-client-id
REACT_APP_ORACLE_REDIRECT_URI=https://your-host.example.com
REACT_APP_ORACLE_SCOPE=openid profile email
REACT_APP_ORACLE_ALLOWED_EMAIL_DOMAINS=oracle.com
REACT_APP_SPRINT_MANAGER_ADMIN_EMAILS=admin1@example.com,admin2@example.com
REACT_APP_ALLOW_DEMO_LOGIN=false

SPRINT_MANAGER_ADMIN_EMAILS=admin1@example.com,admin2@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=notifications@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=Sprint Board <notifications@example.com>
SPRINT_BOARD_DAILY_REPORT_HOUR=8
SPRINT_BOARD_DAILY_REPORT_MINUTE=0

