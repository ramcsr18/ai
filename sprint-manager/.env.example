REACT_APP_ORACLE_DOMAIN_URL=https://your-domain.identity.oraclecloud.com
REACT_APP_ORACLE_CLIENT_ID=your-public-client-id
REACT_APP_ORACLE_REDIRECT_URI=http://localhost:3000
REACT_APP_ORACLE_SCOPE=openid profile email
REACT_APP_ORACLE_ALLOWED_EMAIL_DOMAINS=example.com
REACT_APP_SPRINT_MANAGER_ADMIN_EMAILS=admin@example.com
REACT_APP_ALLOW_DEMO_LOGIN=true

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_JQL=project = ABC ORDER BY updated DESC

BUGDB_API_URL=https://bugdb.example.com/api/bugs
BUGDB_BEARER_TOKEN=your-bugdb-token
